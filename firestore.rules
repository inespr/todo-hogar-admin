rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Colección electrodomésticos - permitir lectura a todos, escritura a autenticados
    match /electrodomesticos/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Colecciones de catálogo
    match /tipos/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /marcas/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /medidas/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Denegar acceso a todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
